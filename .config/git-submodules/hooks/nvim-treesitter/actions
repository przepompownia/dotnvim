#!/usr/bin/env bash
currentDir="$(dirname "$(realpath "${BASH_SOURCE[0]}")")"

runTsUpdate() {
    nvim-xdg-env -u "$(realpath "${currentDir}/../../../..")/nvim/init.lua" -l /dev/stdin <<LUA
require('nvim-treesitter.install').update(nil, {summary = true}):wait()
LUA
}

declare -A patternToAction

patternToAction['^lua/nvim-treesitter/parsers\.lua$']='runTsUpdate'
